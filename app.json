{
  "expo": {
    "name": "arenanp",
    "slug": "arenanp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "app",
    "userInterfaceStyle": "light",
    "androidNavigationBar": {
      "barStyle": "dark-content"
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.arenanp.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.arenanp.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "react-native-edge-to-edge",
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Allow ArenaNepalSport to use your location to place your venue on the map."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ArenaNepalSport to use your location to place your venue on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ArenaNepalSport to access your photos to add venue images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52e97dc7-a9ce-4d03-99e9-d5b44632d980"
      }
    },
    "owner": "arenanepal"
  }
}
