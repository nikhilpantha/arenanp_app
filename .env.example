# Arena NP mobile — environment
#
# Copy to `.env` and set the GraphQL endpoint to switch the app from the on-device
# mock auth to the live backend. When unset/empty, the app uses the mock provider
# (offline development) — see src/lib/auth/index.ts.
#
# Notes:
#  - iOS simulator can use http://localhost:8000/graphql
#  - Android emulator must use http://10.0.2.2:8000/graphql (localhost = the emulator)
#  - A physical device must use your machine's LAN IP, e.g. http://192.168.1.20:8000/graphql
EXPO_PUBLIC_API_URL=

# Existing (already used by the location picker — Google Places API key)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
